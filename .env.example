# ─── InvoiceGua — Environment Variables ───────────────────────────────────────
# Copy file ini jadi .env.local lalu isi nilainya.
# .env.local TIDAK boleh di-commit ke git (sudah ada di .gitignore).
# ──────────────────────────────────────────────────────────────────────────────

# Mode demo — set ke "true" untuk disable registrasi akun baru.
# Berguna saat deploy publik dan tidak ingin semua orang bisa daftar.
# Default: false
VITE_DEMO_MODE=false
